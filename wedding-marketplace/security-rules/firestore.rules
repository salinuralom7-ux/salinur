rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isUser(uid) { return signedIn() && request.auth.uid == uid; }
    function unchanged(field) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == resource.data[field];
    }

    // ---------------- vendors ----------------
    // Public read (marketplace browsing). Vendor edits own profile, but the
    // trust fields (rating, tier, verified, stats) are server-only.
    match /vendors/{vendorId} {
      allow read: if true;
      allow create: if isUser(vendorId)
        && !('rating' in request.resource.data)
        && !('reviewCount' in request.resource.data)
        && !('verified' in request.resource.data)
        && request.resource.data.subscriptionTier == 'free';
      allow update: if isUser(vendorId)
        && unchanged('rating') && unchanged('reviewCount')
        && unchanged('verified') && unchanged('subscriptionTier')
        && unchanged('stats');
      allow delete: if false;

      match /availability/{month} {
        allow read: if true;
        allow write: if isUser(vendorId);
      }
    }

    // ---------------- customers ----------------
    match /customers/{customerId} {
      allow read, update: if isUser(customerId);
      allow create: if isUser(customerId);
      allow delete: if false; // deletion via support flow (DPDP request)
    }

    // ---------------- quotations ----------------
    // Customer opens an enquiry; vendor answers it with a price; the customer
    // accepts via the createBooking function (not by editing this doc).
    match /quotations/{quoteId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.customerId
         || request.auth.uid == resource.data.vendorId);
      allow create: if signedIn()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == 'open';
      allow update: if signedIn()
        // vendor may quote an open enquiry…
        && request.auth.uid == resource.data.vendorId
        && resource.data.status == 'open'
        && request.resource.data.status == 'quoted'
        && request.resource.data.quotedPrice is int
        && request.resource.data.quotedPrice > 0
        // …but cannot reassign the parties
        && unchanged('customerId') && unchanged('vendorId');
      allow delete: if false;
    }

    // ---------------- bookings / payments: server-only writes ----------------
    match /bookings/{bookingId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.customerId
         || request.auth.uid == resource.data.vendorId);
      allow write: if false; // Cloud Functions only (Admin SDK bypasses rules)
    }

    match /payments/{paymentId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.customerId
         || request.auth.uid == resource.data.vendorId);
      allow write: if false;
    }

    // ---------------- reviews ----------------
    // Created via the submitReview function only (it verifies the completed
    // booking). Publicly readable.
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if false;
    }

    // ---------------- conversations (inbox metadata) ----------------
    match /conversations/{conversationId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update: if signedIn() && request.auth.uid in resource.data.participants
        && unchanged('participants');
      allow delete: if false;
    }

    // ---------------- subscriptions / analytics ----------------
    match /subscriptions/{vendorId} {
      allow read: if isUser(vendorId);
      allow write: if false;
    }
    match /analytics/{document=**} {
      allow read, write: if false; // admin dashboard uses Admin SDK
    }
  }
}
